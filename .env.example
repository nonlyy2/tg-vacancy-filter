# --- Telegram credentials ---
# Get these from https://my.telegram.org -> API Development Tools
TG_APP_ID=1234567
TG_APP_HASH=abcdef1234567890abcdef1234567890

# Phone number in international format (the account that will act as the userbot)
TG_PHONE=+77001234567

# Where the login session is persisted. Keep this file secret.
# (On Railway/Render mount a persistent volume to this path OR use TG_SESSION_BASE64.)
SESSION_PATH=session.json

# Optional: base64-encoded contents of session.json.
# Set this on hosts without persistent disks. The bot will materialise the file
# at SESSION_PATH on every boot.
TG_SESSION_BASE64=

# --- Channels to monitor ---
# Comma-separated list of channel IDs (either "-100xxxxxxxxxx" or the raw id).
# To find an id: forward a post from the channel to @userinfobot, or use @getidsbot.
SOURCE_CHANNEL_IDS=-1001111111111,-1002222222222,-1003333333333

# Destination where matches will be posted.
# Allowed values:
#   me                              -> Saved Messages (recommended for a personal feed)
#   <username>                      -> any channel/user the account can reach (no @ required)
#   https://t.me/+AbCdEf123         -> private channel invite link; the userbot
#                                      will auto-join if it is not a member yet
#   https://t.me/joinchat/AbCdEf123 -> legacy invite link form (also supported)
DESTINATION=me

# --- Gemini ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# Free-tier limits (per https://ai.google.dev/gemini-api/docs/rate-limits).
# As of 2026-05 Google has retired gemma-3-27b-it from v1beta and reduced
# free-tier RPD on Gemini Flash variants. Current usable options:
#   gemma-4-26b-a4b-it      -> 30 RPM, 14400 RPD  (RECOMMENDED for backfill)
#   gemini-2.5-flash-lite   -> 15 RPM,  ~1000 RPD (strict JSON, small backfill)
#   gemini-2.5-flash        ->  5 RPM,   250 RPD  (live-only)
# The analyser auto-detects Gemma vs Gemini:
#   - Gemini family: structured JSON via ResponseSchema.
#   - Gemma family : two-line "MATCH: yes|no / REASON: ..." text format
#                    (Gemma rejects SystemInstruction/ResponseSchema and tends
#                    to echo JSON shape templates verbatim on short posts).
# On a paid tier set GEMINI_RPM=0 to disable client-side throttling.
GEMINI_MODEL=gemma-4-26b-a4b-it
GEMINI_RPM=25

# --- Behavior ---
# Ignore messages older than this many seconds when the bot boots (prevents
# re-processing a backlog after short downtime). 0 disables the filter.
# This has nothing to do with BACKFILL_SINCE below — it only affects live updates.
MAX_MESSAGE_AGE_SECONDS=900

# --- One-time history backfill ---
# When set (YYYY-MM-DD, UTC), the bot sweeps messages.getHistory for every
# source channel starting from this date, runs them through Gemini and sends
# matches to DESTINATION. Progress is persisted to BACKFILL_STATE_PATH, so a
# crash or restart resumes instead of starting over.
#
# To trigger a sweep: set BACKFILL_SINCE, start the bot, watch logs for
# "backfill: complete". Leaving the variable set is safe — subsequent boots
# with the same date will no-op. Change the date to force a new sweep.
# BACKFILL_SINCE=2026-04-01
BACKFILL_SINCE=

# Where the resume cursor is stored. Keep this on a persistent volume if you
# don't want a fresh sweep after every redeploy on stateless hosts.
BACKFILL_STATE_PATH=backfill_state.json

# Every match=true verdict is appended here as one JSON object per line
# (time, channel, msg_id, reason, link, source=live|backfill). Persistent
# audit trail independent of the Telegram send — useful if a send fails or
# the destination is later cleared. Set empty to disable.
MATCH_LOG_PATH=matches.jsonl

# Optional log level: debug | info | warn | error
LOG_LEVEL=info
